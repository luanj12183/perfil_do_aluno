<div class="card" style="width: 18rem; position: absolute; top: 100px; left: 0px !important; margin-left: 0px !important; z-index: 9999;">
    <div class="card-body">
        <p class="card-text" style="font-size: 1.25rem;"><strong>Nome:</strong> @ViewBag.Nome</p>
        <p class="card-text"><strong>Curso:</strong> @ViewBag.Curso</p>
        <p class="card-text"><strong>Semestre:</strong> @ViewBag.Semestre</p>
        <a asp-action="Detalhes" asp-route-id="1" class="btn btn-primary">Ver Detalhes</a>
    </div>
</div>
