@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Bem-Vindo</h1>
</div>

<div class="card" style="width: 18rem; margin-top: 20px;">
    <div class="card-body">
    <h5 class="card-title">@ViewBag.Nome</h5>
    <p class="card-text"><strong>Curso:</strong> @ViewBag.Curso</p>
    <p class="card-text"><strong>Semestre:</strong> @ViewBag.Semestre</p>
    <a asp-controller="Aluno" asp-action="Detalhes" asp-route-id="1" class="btn btn-primary">
        Ver Detalhes
        </a>
    </div>
</div>